# =============================================================================
# Docker Compose kök dizin env'i
# Servise özgü detaylı env'ler için backend/.env dosyasına bakın.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=trendanaliz
POSTGRES_PASSWORD=trendanaliz_secret
POSTGRES_DB=trendanaliz_db

# --- Frontend → Backend yönlendirmesi ---
# Tarayıcıdan nginx reverse proxy üzerinden /api'ye gider
NEXT_PUBLIC_API_URL=/api

# --- Seed davranışı ---
# 1 yapıldığında ilk başlatmada superadmin + planlar seed edilir
SEED_ON_START=0

# =============================================================================
# backend/.env içinde zorunlu olarak doldurulması gerekenler (özet):
#
#   JWT_SECRET           — min 32 karakter, kriptografik rastgele
#   JWT_REFRESH_SECRET   — JWT_SECRET'tan FARKLI olmalı, min 32 karakter
#   ENCRYPTION_KEY       — AES-256-GCM için; min 32 karakter
#   DATABASE_URL         — postgres bağlantı stringi
#   REDIS_URL            — Redis (brute-force sayacı + token revoke listesi)
#                          Tanımlı değilse bellek-içi fallback kullanılır
#                          (yalnızca development).
#   CORS_ORIGINS         — Virgülle ayrılmış izinli origin listesi.
#                          Tanımlı değilse FRONTEND_URL kullanılır.
#
# Hızlı secret üretmek için (Linux/macOS):
#   openssl rand -hex 32
# PowerShell:
#   -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 48 | % {[char]$_})
# =============================================================================
