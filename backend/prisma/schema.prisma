datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  // TRIAL kullanımı kaldırıldı (deneme süresi yok); enum geriye dönük uyumluluk için bırakıldı.
  TRIAL
}

enum PaymentMethod {
  CREDIT_CARD
  IBAN
  MANUAL
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PriceSource {
  OWN
  COMPETITOR
}

enum RuleType {
  MATCH_LOWEST
  BEAT_BY_AMOUNT
  BEAT_BY_PERCENT
  FIXED_MARGIN
}

enum CampaignStatus {
  ACTIVE
  ENDED
  SCHEDULED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  IYZICO
  PAYTR
  IBAN
  MANUAL
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String
  name           String
  phone          String?
  role           Role           @default(USER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  isActive       Boolean        @default(true)
  emailVerified  Boolean        @default(false)

  // Bildirim tercihleri (her olay türü için kanal listesi)
  // Örn: { "PRICE_ALERT": ["IN_APP","EMAIL"], "BUYBOX_LOST": ["IN_APP","SMS","EMAIL"], ... }
  // null ise notification.service.ts içindeki DEFAULT_PREFS kullanılır.
  notificationPrefs Json?

  // Relations
  subscriptions  Subscription[]
  trendyolStores TrendyolStore[]
  payments       Payment[]      @relation("UserPayments")
  verifiedPayments Payment[]    @relation("AdminVerifiedPayments")
  notifications  Notification[]
  adminLogs      AdminLog[]

  @@index([email])
}

model Subscription {
  id            String             @id @default(uuid())
  userId        String
  planId        String
  // Default ACTIVE — yeni abonelik kayıtları payment.controller'da açıkça
  // ACTIVE ile oluşturulur. PENDING durumu manuel ödeme onayı bekleyen
  // kayıtlar için kullanılır (admin panelinden onaylanır).
  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           @default(now())
  endDate       DateTime
  autoRenew     Boolean            @default(true)
  paymentMethod PaymentMethod      @default(CREDIT_CARD)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Relations
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan               @relation(fields: [planId], references: [id])
  payments      Payment[]

  @@index([userId])
  @@index([planId])
}

model Plan {
  id              String         @id @default(uuid())
  name            String
  slug            String         @unique
  description     String
  price           Decimal        @db.Decimal(10, 2)
  currency        String         @default("TRY")
  billingCycle    BillingCycle   @default(MONTHLY)
  maxProducts     Int
  maxCompetitors  Int
  refreshInterval Int            // in minutes
  features        Json           // List of feature strings/config
  isActive        Boolean        @default(true)
  isPopular       Boolean        @default(false)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  subscriptions   Subscription[]

  @@index([slug])
}

model TrendyolStore {
  id           String    @id @default(uuid())
  userId       String
  supplierId   String
  apiKey       String
  apiSecret    String
  storeName    String
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]
  campaigns    Campaign[]
  orders       Order[]

  @@index([userId])
  @@index([supplierId])
}

// Trendyol sipariş statüleri (resmi)
enum OrderStatus {
  Created
  Picking
  Invoiced
  Shipped
  ShippedToCollectionPoint
  AtCollectionPoint
  Delivered
  UnDelivered
  UnDeliveredAndReturned
  Cancelled
  Returned
  Awaiting
  UnSupplied
  UnPacked
  Repack
}

model Order {
  id                     String      @id @default(uuid())
  storeId                String

  // Trendyol kimlikleri
  shipmentPackageId      BigInt      @unique
  orderNumber            String
  grossAmount            Decimal     @db.Decimal(12, 2)
  totalDiscount          Decimal     @default(0) @db.Decimal(12, 2)
  totalPrice             Decimal     @db.Decimal(12, 2)
  currencyCode           String      @default("TRY")
  status                 OrderStatus
  cargoTrackingNumber    String?
  cargoProviderName      String?
  cargoTrackingLink      String?
  customerFirstName      String?
  customerLastName       String?
  customerEmail          String?
  customerPhone          String?
  tcIdentityNumber       String?
  taxNumber              String?
  invoiceAddress         Json?
  shipmentAddress        Json?
  orderDate              DateTime
  estimatedDeliveryStart DateTime?
  estimatedDeliveryEnd   DateTime?
  fastDelivery           Boolean     @default(false)
  deliveryType           String?

  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  lastSyncedAt           DateTime    @default(now())

  // Relations
  store                  TrendyolStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items                  OrderItem[]

  @@index([storeId, orderDate])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String?  // platformdaki ürünümüze referans (varsa)

  // Trendyol satır kimlikleri
  lineId          BigInt?
  barcode         String
  productName     String
  merchantSku     String?
  productSize     String?
  productColor    String?
  quantity        Int
  price           Decimal  @db.Decimal(12, 2)   // Tek adet satış fiyatı
  amount          Decimal  @db.Decimal(12, 2)   // Brüt tutar
  discount        Decimal  @default(0) @db.Decimal(12, 2)
  vatBaseAmount   Decimal? @db.Decimal(12, 2)
  lineItemStatus  String?

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([barcode])
}

model Product {
  id             String           @id @default(uuid())
  storeId        String
  barcode        String           @unique
  title          String
  productCode    String?
  salePrice      Decimal          @db.Decimal(10, 2)
  listPrice      Decimal          @db.Decimal(10, 2)
  vatRate        Decimal          @db.Decimal(5, 2)
  stockCount     Int              @default(0)
  categoryId     String?
  brandId        String?
  imageUrl       String?
  listingScore   Float            @default(0.0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  lastFetchedAt  DateTime?

  // Relations
  store          TrendyolStore    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  competitors    Competitor[]      // Manuel rakip ekleme (legacy/opsiyonel)
  buyboxSnapshots BuyBoxSnapshot[] // Resmi Trendyol Buybox API'sinden çekilen snapshot'lar
  priceHistories PriceHistory[]
  priceRules     PriceRule[]
  listingAudits  ListingAudit[]
  salesForecasts SalesForecast[]
  orderItems     OrderItem[]

  @@index([storeId])
  @@index([barcode])
}

model Competitor {
  id                  String         @id @default(uuid())
  productId           String
  competitorSellerId  String
  competitorSellerName String
  currentPrice        Decimal        @db.Decimal(10, 2)
  lastSeenPrice       Decimal        @db.Decimal(10, 2)
  currency            String         @default("TRY")
  inStock             Boolean        @default(true)
  isBuybox            Boolean        @default(false)
  lastCheckedAt       DateTime       @default(now())
  createdAt           DateTime       @default(now())

  // Relations
  product             Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceHistories      PriceHistory[]

  @@index([productId])
  @@index([competitorSellerId])
}

/// Trendyol resmi Buybox Check Service'inden alınan snapshot.
/// API: POST /integration/product/sellers/{sellerId}/products/buybox-information
/// Yanıt: buyboxOrder, buyboxPrice, hasMultipleSeller, secondBuyboxPrice, thirdBuyboxPrice
/// Bu satıcı kimliklerini DEĞİL, fiyat sıralamasını verir. Repricer bu tabloyu okuyarak
/// karar verir; manuel `Competitor` ile karıştırılmamalı.
model BuyBoxSnapshot {
  id                String    @id @default(uuid())
  productId         String
  /// 1 = bu satıcı kazanıyor; 2-N = başkası kazanıyor.
  buyboxOrder       Int
  /// Buybox kazananın güncel satış fiyatı.
  buyboxPrice       Decimal   @db.Decimal(10, 2)
  /// Üründe bizim dışımızda satıcı var mı?
  hasMultipleSeller Boolean   @default(false)
  secondBuyboxPrice Decimal?  @db.Decimal(10, 2)
  thirdBuyboxPrice  Decimal?  @db.Decimal(10, 2)
  /// Bizim o anki fiyatımız (analiz için snapshot'a yazılır).
  ownPrice          Decimal?  @db.Decimal(10, 2)
  checkedAt         DateTime  @default(now())

  // Relations
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, checkedAt])
  @@index([checkedAt])
}

model PriceHistory {
  id           String      @id @default(uuid())
  productId    String
  price        Decimal     @db.Decimal(10, 2)
  source       PriceSource
  competitorId String?
  recordedAt   DateTime    @default(now())

  // Relations
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  competitor   Competitor? @relation(fields: [competitorId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([recordedAt])
}

model PriceRule {
  id              String    @id @default(uuid())
  productId       String
  ruleType        RuleType
  targetValue     Decimal   @db.Decimal(10, 2)
  minPrice        Decimal   @db.Decimal(10, 2)
  maxPrice        Decimal   @db.Decimal(10, 2)
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ListingAudit {
  id               String   @id @default(uuid())
  productId        String
  titleScore       Int
  descriptionScore Int
  imageScore       Int
  categoryScore    Int
  keywordScore     Int
  totalScore       Int
  suggestions      Json     // Array of recommendations
  createdAt        DateTime @default(now())

  // Relations
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model SalesForecast {
  id               String   @id @default(uuid())
  productId        String
  forecastDate     DateTime
  predictedUnits   Int
  predictedRevenue Decimal  @db.Decimal(12, 2)
  confidence       Float
  model            String
  createdAt        DateTime @default(now())

  // Relations
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([forecastDate])
}

model Campaign {
  id           String         @id @default(uuid())
  storeId      String
  campaignName String
  type         String
  startDate    DateTime
  endDate      DateTime
  budget       Decimal        @db.Decimal(10, 2)
  spend        Decimal        @db.Decimal(10, 2)
  revenue      Decimal        @db.Decimal(10, 2)
  roas         Float          @default(0.0)
  impressions  Int            @default(0)
  clicks       Int            @default(0)
  conversions  Int            @default(0)
  status       CampaignStatus @default(SCHEDULED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  store        TrendyolStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  channel   String[]         // IN_APP, EMAIL, SMS
  /// Bildirime tıklayınca yönlenecek frontend URL'i.
  /// Örn: "/dashboard/siparisler/<id>", "/dashboard/buybox?storeId=..."
  linkUrl   String?
  createdAt DateTime         @default(now())

  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  subscriptionId    String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("TRY")
  method            PaymentMethod @default(CREDIT_CARD)
  status            PaymentStatus @default(PENDING)
  provider          PaymentProvider @default(IYZICO)
  providerPaymentId String?
  providerToken     String?
  providerMerchantOid String?
  iyzico_paymentId  String?
  iyzico_token      String?
  ibanSenderName    String?
  ibanNote          String?
  receiptUrl        String?
  verifiedAt        DateTime?
  verifiedByAdminId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user              User          @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  verifiedByAdmin   User?         @relation("AdminVerifiedPayments", fields: [verifiedByAdminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
}

model SiteSettings {
  id                 String   @id @default(uuid())
  key                String   @unique
  value              Json
  updatedAt          DateTime @updatedAt
  updatedByAdminId   String?

  @@index([key])
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String
  detail    Json
  createdAt DateTime @default(now())

  // Relations
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}
