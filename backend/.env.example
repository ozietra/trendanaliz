# Sunucu Ayarları
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Veritabanı ve Redis (Local Docker için localhost, Docker içi için postgres/redis)
DATABASE_URL="postgresql://trendanaliz:trendanaliz_secret@localhost:5432/trendanaliz_db?schema=public"
REDIS_URL="redis://localhost:6379"

# JWT Sırları — ZORUNLU. Min 32 karakter, kriptografik rastgele.
# Birbirinden FARKLI olmalı. Üretim sırları burada DEĞİL, .env içinde olmalı.
# Oluştur: openssl rand -hex 32   (veya PowerShell ile rastgele 64 hex)
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Hassas veri şifreleme (Trendyol API Key/Secret AES-256-GCM ile şifrelenir)
# ZORUNLU. Min 32 karakter.
ENCRYPTION_KEY=""

# Frontend URL (e-posta linkleri için)
FRONTEND_URL="http://localhost:3001"

# CORS izinli origin'ler (virgülle ayrılmış liste)
# Tanımlı değilse FRONTEND_URL kullanılır.
CORS_ORIGINS="http://localhost:3001"

# Süperadmin seed bilgileri (ilk kurulumda kullanılır)
SUPERADMIN_EMAIL="admin@trendanaliz.com"
SUPERADMIN_PASSWORD="Admin1234!"
SUPERADMIN_NAME="Sistem Yöneticisi"

# E-posta (SMTP) Yapılandırması
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_pass"
SMTP_FROM="noreply@trendanaliz.com"

# Iyzico Sanal Pos
IYZICO_API_KEY="your_iyzico_api_key"
IYZICO_SECRET_KEY="your_iyzico_secret_key"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# PayTR Sanal Pos (iFrame API)
# Boş bırakılırsa MOCK akış çalışır (geliştirme için)
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE="1"

# Trendyol Satıcı API
TRENDYOL_API_BASE="https://apigw.trendyol.com"
TRENDYOL_USER_AGENT_SUFFIX="SelfIntegration"
TRENDYOL_TIMEOUT_MS="15000"
TRENDYOL_MAX_RETRIES="3"
TRENDYOL_LIVE_PUSH="0"

# Netgsm / Twilio SMS
# Boş bırakılırsa MOCK akış çalışır (içerik log'a yazılır).
SMS_PROVIDER="netgsm"
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_HEADER=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# Geliştirme/Simülasyon Bayrakları
# 1 yapılırsa repricer Math.random ile sahte rakip fiyatı dalgalanır.
# PROD'da MUTLAKA 0 olmalı (validateEnv kontrol eder).
SIMULATE_COMPETITORS="0"

# Cron Aralıkları (ms cinsinden, isteğe bağlı)
# ORDER_SYNC_INTERVAL_MS=300000          # 5 dk
# SUBSCRIPTION_CRON_INTERVAL_MS=21600000 # 6 saat
